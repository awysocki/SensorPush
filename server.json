{
  "name": "SensorPush",
  "docs": "https://github.com/awysocki/SensorPush",
  "type": "python3",
  "executable": "main.py",
  "install": "install.sh",
  "shortPoll": 60,
  "longPoll": 300,
  "restart": true,
  "interface": "mqtt",
  "version": "2026.7.021",
  "discover": true,
  "oauth": false,
  "status_node": "controller",
  "status_driver": "ST",
  "customparams": {
    "sensorpush_email": "",
    "sensorpush_password": "",
    "use_short_poll_updates": "0",
    "sample_limit": "1",
    "sensor_stale_hours": "1",
    "sensor_stale_notify_recovery": "1",
    "ntfy_topic": "",
    "ntfy_server": "https://ntfy.sh",
    "ntfy_token": ""
  },
  "credits": [
    {
      "title": "SensorPush",
      "version": "2026.7.021"
    }
  ],
  "profile_version": "9",
  "description": "PG3 for SensorPush cloud API with configurable short/long poll update mode.",
  "id": "sensorpush"
}